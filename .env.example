# ─────────────────────────────────────────────────────────
#  DaVinci Resolve MCP — environment configuration
#  Copy this file to .env and fill in your paths.
#  Run `node test.js` to verify everything works.
# ─────────────────────────────────────────────────────────

# REQUIRED — path to your Python executable (3.10 or later)
#
# Windows:  C:\Users\<YourName>\AppData\Local\Programs\Python\Python3XX\python.exe
# macOS:    /usr/bin/python3   (or: which python3)
# Linux:    /usr/bin/python3
PYTHON_PATH=

# OPTIONAL — only needed if DaVinci Resolve is installed in a non-standard location.
# Leave blank to use the built-in auto-detection.
#
# Path to fusionscript.dll (Windows) or fusionscript.so (macOS/Linux)
# Windows default:  C:\Program Files\Blackmagic Design\DaVinci Resolve\fusionscript.dll
# macOS default:    /Applications/DaVinci Resolve/DaVinci Resolve.app/Contents/Libraries/Fusion/fusionscript.so
RESOLVE_SCRIPT_LIB=
