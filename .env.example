# OPTIONAL — only needed if DaVinci Resolve Studio is installed in a non-standard location.
# Leave blank if you used the default installer.
#
# Path to fusionscript.dll (Windows) or fusionscript.so (macOS/Linux)
# Windows default:  C:\Program Files\Blackmagic Design\DaVinci Resolve\fusionscript.dll
# macOS default:    /Applications/DaVinci Resolve/DaVinci Resolve.app/Contents/Libraries/Fusion/fusionscript.so
RESOLVE_SCRIPT_LIB=
